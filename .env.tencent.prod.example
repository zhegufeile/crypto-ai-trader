ENV=prod
USE_SIMULATION=true
DATABASE_URL=sqlite:///./crypto_ai_trader.db

SCAN_INTERVAL_SECONDS=300
MAX_CANDIDATES=10
CANDIDATE_BUFFER_MULTIPLIER=2
SNAPSHOT_FETCH_CONCURRENCY=4
CONFIDENCE_THRESHOLD=0.72
MIN_RR=2.2
MIN_VOLUME_USDT=50000000
MIN_RELATIVE_STRENGTH_SCORE=0.60
MIN_FOLLOW_THROUGH_SCORE=0.48
MIN_RETEST_QUALITY_SCORE=0.55

SIGNAL_STRATEGY_TIER_MODE=core-only
CORE_STRATEGY_BONUS_MULTIPLIER=1.4
CANDIDATE_STRATEGY_BONUS_MULTIPLIER=1.0
WATCHLIST_STRATEGY_BONUS_MULTIPLIER=0.45
TIER_SCORE_BONUS_SCALE=0.06
SIMULATION_STARTING_BALANCE_USDT=10000

MAX_POSITION_NOTIONAL_USDT=100
MAX_OPEN_POSITIONS=3
MAX_SAME_DIRECTION_POSITIONS=2
MAX_SAME_STRUCTURE_POSITIONS=2
DAILY_MAX_LOSS_USDT=50
MAX_CONSECUTIVE_LOSSES=2
SYMBOL_COOLDOWN_MINUTES=90
PENDING_ENTRY_TIMEOUT_MINUTES=30
TRADE_ACTION_CIRCUIT_WINDOW_MINUTES=15
MAX_TRADE_ACTIONS_IN_WINDOW=6
MAX_TRADE_STATE_CHANGES_PER_SCAN=4
BLACKLISTED_SYMBOLS=[]

MARKET_DATA_SOURCE=binance
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_SPOT_BASE_URL=https://api.binance.com
BINANCE_PROXY_URL=
BINANCE_PROXY_FALLBACK_ENABLED=true
COINGLASS_API_KEY=

ENABLE_ONCHAIN_SIGNAL_BOOST=true
ONCHAIN_SIGNAL_SNAPSHOT_FILE=data/onchainos/signals.snapshot.json
MIN_ONCHAIN_SIGNAL_SCORE=0.55
ONCHAIN_RISK_SNAPSHOT_FILE=data/onchainos/risks.snapshot.json

OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
FRONTEND_ORIGINS=["https://www.pluseclould.xyz"]
